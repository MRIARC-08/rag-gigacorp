# Root .gitignore

# Mac OS
.DS_Store

# IDEs
.vscode/
.idea/

# Backend
backend/.venv/
backend/__pycache__/
backend/*.pyc
backend/.env
backend/chroma_db/
backend/alembic/versions/*
!backend/alembic/versions/.gitkeep

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/coverage/

# Environment Keys (Keep local)
enviroement-keys.md
